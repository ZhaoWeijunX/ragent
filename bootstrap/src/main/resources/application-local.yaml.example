# 本地开发配置模板
# 复制为 application-local.yaml 后填入真实值
#
#   cp application-local.yaml.example application-local.yaml

ragent:
  infra:
    host: localhost

ai:
  providers:
    bailian:
      api-key: your-bailian-api-key
    aihubmix:
      api-key: your-aihubmix-api-key
    siliconflow:
      api-key: your-siliconflow-api-key
    deepseek:
      api-key: your-deepseek-api-key

feishu:
  app-id: your-feishu-app-id
  app-secret: your-feishu-app-secret
  # tenant-access-token: your-feishu-tenant-token  # 可选，非空时优先于 app-id/app-secret

mineru:
  api-key: your-mineru-api-key

rag:
  search:
    channels:
      web-search:
        api-key: your-api-key