# Copy to repo-root .env and fill real values. Do not commit .env.
#
#   cp .env.example .env
#
# Spring Boot does NOT auto-load .env. Inject before start:
#   - IDEA: Run Configuration -> Environment variables -> load this file (EnvFile)
#   - PowerShell: . .\scripts\export-dotenv.ps1
#   - bash: set -a && source .env && set +a
#
# GraphRAG Compose still uses resources/docker/graphrag/.env separately.

# --- bootstrap: AI providers ---
BAILIAN_API_KEY=
AIHUBMIX_API_KEY=
SILICONFLOW_API_KEY=
DEEPSEEK_API_KEY=

# --- bootstrap: integrations ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# FEISHU_TENANT_TOKEN=
MINERU_API_KEY=
YDC_API_KEY=

# --- mcp-server: QWeather ---
QWEATHER_API_KEY=
QWEATHER_API_HOST=

# --- middleware host (PG / Redis / RocketMQ / RustFS; default localhost) ---
RAGENT_INFRA_HOST=localhost
