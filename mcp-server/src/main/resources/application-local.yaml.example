# 本地开发配置模板
# 复制为 application-local.yaml 后填入真实值（该文件已加入 .gitignore）
#
#   cp application-local.yaml.example application-local.yaml
#
# API Host 获取：https://console.qweather.com/setting
#
# 业务 PG 查询（sales_query / ticket_query）与 bootstrap 共用 ragent 库
# spring:
#   datasource:
#     url: jdbc:postgresql://localhost:5432/ragent?client_encoding=UTF8
#     username: postgres
#     password: your-password

weather:
  qweather:
    api-key: your-qweather-api-key-here
    api-host: your-api-host.qweatherapi.com   # 控制台复制，可带或不带 https://
