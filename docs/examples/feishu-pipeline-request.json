{
  "name": "feishu-ingestion-pipeline",
  "description": "飞书云文档 / 知识库 Wiki 摄取流水线 - 拉取纯文本、结构化分块、向量化",
  "nodes": [
    {
      "nodeId": "fetcher-1",
      "nodeType": "fetcher",
      "nextNodeId": "parser-1"
    },
    {
      "nodeId": "parser-1",
      "nodeType": "parser",
      "settings": {
        "rules": [
          {
            "mimeType": "MARKDOWN"
          },
          {
            "mimeType": "TEXT"
          }
        ]
      },
      "nextNodeId": "chunker-1"
    },
    {
      "nodeId": "chunker-1",
      "nodeType": "chunker",
      "settings": {
        "strategy": "structure_aware",
        "chunkSize": 1400,
        "overlapSize": 0,
        "rowsPerChunk": 40
      },
      "nextNodeId": "indexer-1"
    },
    {
      "nodeId": "indexer-1",
      "nodeType": "indexer",
      "settings": {
        "embeddingModel": "qwen-emb-8b",
        "metadataFields": [
          "source_type",
          "source_location"
        ]
      }
    }
  ]
}
