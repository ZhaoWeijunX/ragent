{
  "name": "feishu-markdown-ingestion-pipeline",
  "description": "飞书云文档摄取流水线（Markdown 格式）- Markdown 解析、结构感知分块、向量化",
  "nodes": [
    {
      "nodeId": "feishu_fetcher-1",
      "nodeType": "fetcher",
      "settings": null,
      "condition": null,
      "nextNodeId": "feishu_parser-1"
    },
    {
      "nodeId": "feishu_parser-1",
      "nodeType": "parser",
      "settings": {
        "rules": [
          {
            "mimeType": "MARKDOWN"
          },
          {
            "mimeType": "TEXT"
          }
        ]
      },
      "condition": null,
      "nextNodeId": "feishu_chunker-1"
    },
    {
      "nodeId": "feishu_chunker-1",
      "nodeType": "chunker",
      "settings": {
        "strategy": "structure_aware",
        "chunkSize": 1400,
        "overlapSize": 0
      },
      "condition": null,
      "nextNodeId": "feishu_indexer-1"
    },
    {
      "nodeId": "feishu_indexer-1",
      "nodeType": "indexer",
      "settings": {
        "embeddingModel": "qwen-emb-8b",
        "metadataFields": [
          "source_type",
          "source_location"
        ]
      },
      "condition": null,
      "nextNodeId": null
    }
  ]
}
