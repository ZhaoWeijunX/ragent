# 复制本文件为同目录 .env 后填写实际值。
# Docker Compose（包括 IDEA 的 Compose 启动按钮）会自动读取同目录 .env。

# LightRAG 镜像版本
LIGHTRAG_IMAGE_TAG=latest

# Neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=ragent123456
NEO4J_DATABASE=neo4j

# 宿主机 PostgreSQL（需安装 pgvector）
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=ragent

# 在线 LLM：阿里云百炼 OpenAI 兼容接口
LLM_BINDING=openai
LLM_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus-latest
# 实体 / 关系描述与摘要的输出语言（English / 简体中文 ...），默认简体中文；改后需重建索引才对已有数据生效
SUMMARY_LANGUAGE=简体中文
BAILIAN_API_KEY=sk-请填写

# 在线 Embedding：SiliconFlow OpenAI 兼容接口
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# 必须与 application.yaml 的 rag.default.dimension 一致
EMBEDDING_DIM=1536
SILICONFLOW_API_KEY=sk-请填写
